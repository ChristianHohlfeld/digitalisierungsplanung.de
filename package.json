{
  "name": "digitalisierungsplanung-state-tool",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build:index": "node scripts/build-index.mjs",
    "build:pwa-assets": "node scripts/build-pwa-assets.mjs",
    "build:release-version": "node scripts/write-release-version.mjs --increment",
    "server:start": "node server/server.js",
    "server:smoke:wss": "node server/wss-smoke.js",
    "server:smoke:wss:prod": "node server/wss-smoke.js --force-ip=198.199.83.43",
    "server:smoke:emit": "node server/emit-smoke.js",
    "server:smoke:emit:prod": "node server/emit-smoke.js --force-ip=198.199.83.43",
    "test": "npm run test:server && npm run test:browser",
    "test:server": "node --test server/real-daisyui.test.js",
    "test:browser": "playwright test tests/real-daisyui.spec.js --reporter=list",
    "test:contracts": "npm run test:server",
    "test:state-explorer": "npm run test:browser",
    "test:state-render": "npm run test:browser",
    "test:full": "npm run test:server && npm run test:browser",
    "test:headed": "playwright test tests/real-daisyui.spec.js --headed",
    "test:ui": "playwright test tests/real-daisyui.spec.js --ui",
    "mcp:state": "node mcp/state-blueprint-server.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  },
  "dependencies": {
    "parse5": "6.0.1",
    "ws": "^8.21.0"
  }
}
