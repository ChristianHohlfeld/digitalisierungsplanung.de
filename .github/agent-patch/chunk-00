import fs from "node:fs";

function replaceOnce(source, before, after, label) {
  const index = source.indexOf(before);
  if (index < 0) throw new Error("Missing patch anchor: " + label);
  if (source.indexOf(before, index + before.length) >= 0) throw new Error("Ambiguous patch anchor: " + label);
  return source.slice(0, index) + after + source.slice(index + before.length);
}

function extractAppHtml(source) {
  const declaration = "const APP_HTML = ";
  const start = source.indexOf(declaration);
  if (start < 0) throw new Error("APP_HTML declaration missing");
  const literalStart = start + declaration.length;
  if (source[literalStart] !== '"') throw new Error("APP_HTML is not a JSON string literal");
  let escaped = false;
  for (let index = literalStart + 1; index < source.length; index += 1) {
    const char = source[index];
    if (escaped) {
      escaped = false;
      continue;
    }
    if (char === "\\") {
      escaped = true;
      continue;
    }
    if (char === '"') {
      return {
        value: JSON.parse(source.slice(literalStart, index + 1)),
        literalStart,
        literalEnd: index + 1
      };
    }
  }
  throw new Error("APP_HTML closing quote missing");
}

